# =========================
# SERVER CONFIG
# =========================

# App
PORT=5002
NODE_ENV=development

# =========================
# DATABASE
# =========================

# Full connection string (recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/mymental

# Individual fields (optional, if not using DATABASE_URL)
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=mymental_db

# =========================
# SESSION
# =========================

# Used to sign session cookies (use a long random string in production)
SESSION_SECRET=your_super_secret_session_key_here

# =========================
# REDIS (OPTIONAL)
# =========================

# Used for session storage / caching 
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# =========================
# ASSEMBLYAI
# =========================

# Fallback API key (used if user does not provide their own)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# =========================
# ENCRYPTION
# =========================

# Used to encrypt stored API keys
API_KEY_ENCRYPTION_SECRET=your_encryption_secret_here

# =========================
# AWS (EMAIL / SES)
# =========================

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-central-1

# Sender email (must be verified in AWS SES)
EMAIL_FROM="myMental <your-email@example.com>"

# =========================
# APP CONFIG
# =========================

# Frontend URL (used for CORS, redirects, email links)
APP_ORIGIN=http://localhost:3002

# =========================
# GOOGLE OAUTH
# =========================

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match Google Cloud Console config
GOOGLE_REDIRECT_URI=http://localhost:5002/auth/google/callback